# Versionskontrolle ignorieren
.git

# Lokale Umgebungen und Caches ignorieren
venv/
env/
__pycache__/
*.pyc

# Sensible Dateien ignorieren (Ganz wichtig!)
.env
secrets.json

# Test- oder Entwickler-Ordner ignorieren
_datasets/
_experiments/
_models/
_safespace/
mathematica/
test_pipeline/

# Logs und Datenbanken niemals committen (lokal generiert, teils > 100 MB)
*.db
*.sqlite
*.sqlite3
*.log
logs/
mlruns/
mlartifacts/
mlflow.db

# Trainings-Artefakte / generierte Ergebnisse (Checkpoints, Plots, Metriken; teils GB-gross).
# run_results/ enthaelt Quellcode (*.py) UND generierte Experiment-Outputs — nur Letztere ignorieren.
*.ckpt
codebase/src/gnn/supervised_learning/run_results/**
!codebase/src/gnn/supervised_learning/run_results/
!codebase/src/gnn/supervised_learning/run_results/*.py

# Stray single-run GraphGym outputs (default out_dir when no experiment name given)
codebase/src/agg/
codebase/src/results/
codebase/src/gnn/supervised_learning/results/
codebase/src/gnn/supervised_learning/agg/

# Generated plots / visualizations (regenerable from the scripts that emit them)
codebase/src/gnn/output_plots/
codebase/src/gnn/supervised_learning/visualizations/
*.gexf

# Datasets and their archive (bulk input data, unpacked locally — never commit)
datasets/
datasets.zip

# Cached converted graph tensors
*.pt
*_augmented.pt